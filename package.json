{
  "name": "trading-journal",
  "productName": "Trading Journal",
  "version": "1.0.0",
  "description": "Diario de trading personal con sincronización Supabase y modo offline-first.",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start:staging": "cross-env APP_BUILD_ENV=staging electron-forge start",
    "start:production": "cross-env APP_BUILD_ENV=production electron-forge start",
    "clean": "node -e \"const fs=require('fs');for (const p of ['out','.webpack']) { try { fs.rmSync(p,{recursive:true,force:true}); console.log('Eliminado:', p); } catch (e) { if (e.code!=='ENOENT') throw e; } }\"",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:staging": "cross-env APP_BUILD_ENV=staging electron-forge make",
    "make:production": "cross-env APP_BUILD_ENV=production electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "Javier Lao",
    "email": "javilaox@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "dotenv": "^17.4.2",
    "electron": "41.3.0",
    "node-loader": "^2.1.0",
    "style-loader": "^3.3.4",
    "supabase": "^2.98.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "electron-squirrel-startup": "^1.0.1",
    "sqlite3": "^6.0.1"
  }
}
